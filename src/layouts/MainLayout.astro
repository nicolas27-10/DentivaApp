---
interface Props {
  title?: string;
}

const { title = 'Dentiva - Valida tu título dental en Alemania' } = Astro.props;
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Plataforma educativa para dentistas que buscan validar su título profesional en Alemania" />
    <link rel="icon" type="image/png" sizes="32x32" href="/DentivaLogoSm.png" />
    <link rel="apple-touch-icon" href="/DentivaLogoSm.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <meta name="theme-color" content="#4AAED9" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-background text-textMain">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
