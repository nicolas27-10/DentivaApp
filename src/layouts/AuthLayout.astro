---
interface Props {
  title?: string;
}

const { title = 'Dentiva' } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" sizes="32x32" href="/DentivaLogoSm.png" />
    <link rel="apple-touch-icon" href="/DentivaLogoSm.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <meta name="theme-color" content="#4AAED9" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex items-center justify-center bg-background text-textMain">
    <div class="w-full max-w-md">
      <a href="/" class="block text-center text-2xl font-bold text-primary mb-8">
        Dentiva
      </a>
      <main class="bg-card rounded-lg shadow-md p-8 border border-border">
        <slot />
      </main>
      <p class="text-center text-sm text-textMain/70 mt-6">
        <a href="/" class="hover:text-primary">← Volver al inicio</a>
      </p>
    </div>
  </body>
</html>
