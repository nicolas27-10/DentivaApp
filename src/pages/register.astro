---
import AuthLayout from '../layouts/AuthLayout.astro';
import { signUp } from '../lib/auth';
import { getSession } from "../lib/auth";

const session = await getSession(Astro.cookies);

if (session) {
  return Astro.redirect("/dashboard");
}

let errorMessage: string | null = null;
let successMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const contentType = Astro.request.headers.get('content-type') ?? '';

  if (
    !contentType.includes('application/x-www-form-urlencoded') &&
    !contentType.includes('multipart/form-data')
  ) {
    errorMessage = 'Das Formular konnte nicht verarbeitet werden (ungültiger Content-Type).';
  } else {
    const formData = await Astro.request.formData();
    const firstName = String(formData.get('first_name') ?? '').trim();
    const lastName = String(formData.get('last_name') ?? '').trim();
    const email = String(formData.get('email') ?? '').trim();
    const password = String(formData.get('password') ?? '');

    if (!firstName || !lastName || !email || !password) {
      errorMessage = 'Bitte füllen Sie alle Felder aus.';
    } else {
      // Pasamos first_name y last_name a la función signUp
      const { error } = await signUp(email, password, { 
        first_name: firstName, 
        last_name: lastName 
      });

      if (error) {
        errorMessage = error.message ?? 'Das Konto konnte nicht erstellt werden.';
      } else {
        successMessage =
          'Konto erfolgreich erstellt. Bitte überprüfen Sie Ihre E-Mail oder melden Sie sich an.';
        return Astro.redirect('/dashboard');
      }
    }
  }
}
---

<AuthLayout title="Registrieren - Dentiva">
  <h1 class="text-2xl font-bold text-textMain mb-6">Konto erstellen</h1>

  {errorMessage && (
    <p class="mb-4 text-sm text-error bg-error/10 border border-error/30 rounded-lg px-4 py-3">
      {errorMessage}
    </p>
  )}

  {successMessage && (
    <p class="mb-4 text-sm text-success bg-success/10 border border-success/30 rounded-lg px-4 py-3">
      {successMessage}
    </p>
  )}

  <form
    class="space-y-4"
    method="post"
    action="/register"
    enctype="application/x-www-form-urlencoded"
  >
    <!-- Nombre y Apellido en una fila de 2 columnas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="first_name" class="block text-sm font-medium text-textMain/80 mb-1">
          Vorname
        </label>
        <input
          type="text"
          id="first_name"
          name="first_name"
          required
          class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
          placeholder="Max"
        />
      </div>
      <div>
        <label for="last_name" class="block text-sm font-medium text-textMain/80 mb-1">
          Nachname
        </label>
        <input
          type="text"
          id="last_name"
          name="last_name"
          required
          class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
          placeholder="Mustermann"
        />
      </div>
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-textMain/80 mb-1">
        E-Mail
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
        placeholder="deine@email.de"
      />
    </div>

    <div>
      <label for="password" class="block text-sm font-medium text-textMain/80 mb-1">
        Passwort
      </label>
      <input
        type="password"
        id="password"
        name="password"
        required
        minlength="6"
        class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
        placeholder="Mindestens 6 Zeichen"
      />
    </div>

    <div class="flex items-start">
      <div class="flex h-5 items-center">
        <input
          id="terms"
          name="terms"
          type="checkbox"
          required
          class="h-4 w-4 cursor-pointer rounded border-border bg-background text-primary focus:ring-primary"
        />
      </div>
      <div class="ml-3 text-sm">
        <label for="terms" class="cursor-pointer font-medium text-textMain/80">
          Ich akzeptiere die{' '}
          <a href="/agb" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">
            AGB
          </a>{' '}
          und habe die{' '}
          <a
            href="/datenschutz"
            class="text-primary hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Datenschutzerklärung
          </a>{' '}
          zur Kenntnis genommen.
        </label>
      </div>
    </div>

    <button
      type="submit"
      class="w-full py-3 px-4 bg-accent hover:bg-accent/90 text-white font-medium rounded-lg transition-colors"
    >
      Registrieren
    </button>
  </form>

  <p class="mt-4 text-sm text-textMain/70">
    Haben Sie bereits ein Konto?{' '}
    <a href="/login" class="text-primary hover:underline">Anmelden</a>
  </p>
</AuthLayout>