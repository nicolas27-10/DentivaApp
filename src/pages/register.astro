---
import AuthLayout from '../layouts/AuthLayout.astro';
import { signUp } from '../lib/auth';
import { getSession } from "../lib/auth";

const session = await getSession();

if (session) {
  return Astro.redirect("/dashboard");
}

let errorMessage: string | null = null;
let successMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const contentType = Astro.request.headers.get('content-type') ?? '';

  if (
    !contentType.includes('application/x-www-form-urlencoded') &&
    !contentType.includes('multipart/form-data')
  ) {
    errorMessage = 'No se pudo procesar el formulario (Content-Type inválido).';
  } else {
    const formData = await Astro.request.formData();
    const name = String(formData.get('name') ?? '').trim();
    const email = String(formData.get('email') ?? '').trim();
    const password = String(formData.get('password') ?? '');

    if (!name || !email || !password) {
      errorMessage = 'Por favor completa todos los campos.';
    } else {
      const { error } = await signUp(email, password, { name });

      if (error) {
        errorMessage = error.message ?? 'No se pudo crear la cuenta.';
      } else {
        // Usuario creado en Supabase: mostramos mensaje y podrías redirigir si quieres.
        successMessage = 'Cuenta creada correctamente. Revisa tu email o inicia sesión.';
        return Astro.redirect('/dashboard')
      }
    }
  }
}
---

<AuthLayout title="Registrarse - Dentiva">
  <h1 class="text-2xl font-bold text-textMain mb-6">Crear cuenta</h1>

  {errorMessage && (
    <p class="mb-4 text-sm text-error bg-error/10 border border-error/30 rounded-lg px-4 py-3">
      {errorMessage}
    </p>
  )}

  {successMessage && (
    <p class="mb-4 text-sm text-success bg-success/10 border border-success/30 rounded-lg px-4 py-3">
      {successMessage}
    </p>
  )}

  <form
    class="space-y-4"
    method="post"
    action="/register"
    enctype="application/x-www-form-urlencoded"
  >
    <div>
      <label for="name" class="block text-sm font-medium text-textMain/80 mb-1">
        Nombre
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
        placeholder="Tu nombre"
      />
    </div>
    <div>
      <label for="email" class="block text-sm font-medium text-textMain/80 mb-1">
        Email
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
        placeholder="tu@email.com"
      />
    </div>
    <div>
      <label for="password" class="block text-sm font-medium text-textMain/80 mb-1">
        Contraseña
      </label>
      <input
        type="password"
        id="password"
        name="password"
        required
        minlength="6"
        class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
        placeholder="Mínimo 6 caracteres"
      />
    </div>
    <button
      type="submit"
      class="w-full py-3 px-4 bg-accent hover:bg-accent/90 text-white font-medium rounded-lg transition-colors"
    >
      Registrarse
    </button>
  </form>
  <p class="mt-4 text-sm text-textMain/70">
    ¿Ya tienes cuenta? <a href="/login" class="text-primary hover:underline">Iniciar sesión</a>
  </p>
</AuthLayout>
