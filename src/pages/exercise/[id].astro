---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { supabase } from "../../lib/supabaseClient";

export const prerender = false;

const { id } = Astro.params;

// 1. Obtener sesión para la API
const { data: { session } } = await supabase.auth.getSession();
const userId = session?.user?.id;

// 2. Obtener ejercicio actual
const { data: exercise } = await supabase
  .from("exercises")
  .select("*")
  .eq("id", id)
  .single();

// 3. Obtener opciones (estará vacío si es flashcard)
const { data: options } = await supabase
  .from("exercise_options")
  .select("*")
  .eq("exercise_id", id);

// 4. Calcular el VERDADERO siguiente ejercicio de esta lección
const { data: nextEx } = await supabase
  .from("exercises")
  .select("id")
  .eq("lesson_id", exercise.lesson_id)
  .gt("order_index", exercise.order_index)
  .order("order_index", { ascending: true })
  .limit(1)
  .maybeSingle();

const nextExerciseId = nextEx?.id || null;
---

<DashboardLayout title="Estudio">
  
  <div 
    id="exercise-container" 
    data-exercise-id={exercise.id} 
    data-user-id={userId} 
    data-next-id={nextExerciseId}
    data-lesson-id={exercise.lesson_id}
    data-type={exercise.type}
    class="max-w-2xl mx-auto"
  >

    <div class="mb-6">
      <a href={`/lesson/${exercise.lesson_id}`} class="text-primary hover:underline text-sm font-medium">
        &larr; Volver a la lección
      </a>
    </div>

    <div class="mb-6 flex items-center justify-between">
      <span class="text-sm font-bold text-textMain/50 uppercase tracking-wider">
        {exercise.type === 'multiple_choice' ? 'Test de Práctica' : 'Flashcard'}
      </span>
    </div>

    <h1 class="text-2xl font-bold mb-8 text-textMain">
      {exercise.question_text}
    </h1>

    <div id="quiz-form" class="space-y-4">
      
      {/* RENDER CONDICIONAL: Si es selección múltiple */}
      {exercise.type === 'multiple_choice' && options?.map((option) => (
        <label
          class="block border-2 border-border p-4 rounded-xl cursor-pointer hover:border-primary transition-all bg-card"
          data-option-id={option.id}
        >
          <input type="radio" name="answer" value={option.id} class="mr-3 w-4 h-4 text-primary" />
          <span class="text-lg">{option.option_text}</span>
        </label>
      ))}

      {/* RENDER CONDICIONAL: Si es Flashcard */}
      {exercise.type === 'flashcard' && (
        <div class="p-8 border-2 border-dashed border-border rounded-xl text-center bg-card mb-4">
          <p class="text-textMain/70 italic mb-4">Piensa en la respuesta o definición...</p>
        </div>
      )}

      <div id="explanation-box" class="hidden mt-6 p-5 bg-blue-50 border-l-4 border-blue-500 rounded-r-lg text-blue-900">
        <h4 class="font-bold mb-1">Explicación:</h4>
        <p id="explanation-text"></p>
      </div>

      <div class="flex items-center justify-between mt-8 pt-6 border-t border-border">
        <button
          type="button"
          id="submit-answer"
          class="bg-primary text-white font-bold px-8 py-3 rounded-xl hover:bg-primary/90 transition-all shadow-md"
        >
          {exercise.type === 'multiple_choice' ? 'Comprobar Respuesta' : 'Ver Respuesta'}
        </button>
        <div id="exercise-navigation"></div>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  const container = document.getElementById("exercise-container");
  const button = document.getElementById("submit-answer");
  const explanationBox = document.getElementById("explanation-box");
  const explanationText = document.getElementById("explanation-text");
  
  button?.addEventListener("click", async () => {
    if (!container || !(button instanceof HTMLButtonElement)) return;

    const exId = container.dataset.exerciseId;
    const userId = container.dataset.userId;
    const nextId = container.dataset.nextId;
    const lessonId = container.dataset.lessonId;
    const type = container.dataset.type;

    let optionId = "0"; // Default para flashcards

    // Validar si es selección múltiple
    if (type === 'multiple_choice') {
      const selected = document.querySelector('input[name="answer"]:checked');
      if (!(selected instanceof HTMLInputElement)) {
        alert("Por favor, selecciona una opción.");
        return;
      }
      optionId = selected.value;
    }

    // Estado de carga
    button.disabled = true;
    const originalText = button.textContent;
    button.textContent = "Revisando...";

    try {
      // Llamada a la API unificada
      const response = await fetch("/api/check-answer", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ exerciseId: exId, optionId, userId }),
      });

      const data = await response.json();

      // Feedback visual para selección múltiple
      if (type === 'multiple_choice') {
        const labels = document.querySelectorAll("#quiz-form label");
        labels.forEach((label) => {
          const optId = label.getAttribute("data-option-id");
          if (optId == data.correctOptionId) {
            label.classList.add("border-green-500", "bg-green-50");
          } else if (!data.correct && optId == optionId) {
            label.classList.add("border-red-500", "bg-red-50");
          }
        });

        // Bloquear inputs
        document.querySelectorAll('input[name="answer"]').forEach((input) => {
          if (input instanceof HTMLInputElement) input.disabled = true;
        });
      }

      // Mostrar explicación SIEMPRE (Modo Lernen)
      if (explanationBox && explanationText && data.explanation) {
        explanationText.textContent = data.explanation;
        explanationBox.classList.remove("hidden");
      }

      // Desactivar botón principal
      button.classList.add("opacity-50", "hidden");

      // Generar botón de navegación dinámica
      const nav = document.getElementById("exercise-navigation");
      if (nav) {
        if (nextId) {
          // Si hay siguiente ejercicio, vamos a él
          nav.innerHTML = `
            <a href="/exercise/${nextId}" class="inline-block bg-accent text-white font-bold px-8 py-3 rounded-xl hover:bg-accent/90 transition-transform hover:-translate-y-1 shadow-md">
              Siguiente →
            </a>
          `;
        } else {
          // Si no hay más, volvemos al Lobby de la lección (que ahora calculará el 100%)
          nav.innerHTML = `
            <a href="/lesson/${lessonId}" class="inline-block bg-green-500 text-white font-bold px-8 py-3 rounded-xl hover:bg-green-600 transition-transform hover:-translate-y-1 shadow-md">
              Finalizar Lección ✅
            </a>
          `;
        }
      }

    } catch (error) {
      console.error(error);
      alert("Hubo un error al guardar tu respuesta.");
      button.disabled = false;
      button.textContent = originalText;
    }
  });
</script>