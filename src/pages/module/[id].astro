---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { supabase } from "../../lib/supabaseClient";
import { getSession } from '@/lib/auth'; // ✅ Importación correcta

export const prerender = false;

const { id } = Astro.params;

// 1. Obtener el usuario actual desde nuestra función segura
const user = await getSession(Astro.cookies);

// 🛑 GUARDIA: Si no hay usuario, lo mandamos al login
if (!user) {
  return Astro.redirect('/login');
}

const userId = user.id;

// 🔑 EXTRAER EL TOKEN PARA LAS CONSULTAS
const token = Astro.cookies.get('sb-access-token')?.value;

// 2. Obtener la información del Módulo (¡Con Token!)
const { data: moduleData } = await supabase
  .from("modules")
  .select("*")
  .eq("id", id)
  .single()
  .setHeader('Authorization', `Bearer ${token}`);

if (!moduleData) {
  return Astro.redirect('/dashboard');
}

// 3. Obtener TODAS las lecciones de este módulo (¡Con Token!)
const { data: lessons } = await supabase
  .from("lessons")
  .select("*")
  .eq("module_id", id)
  .order("order_index", { ascending: true })
  .setHeader('Authorization', `Bearer ${token}`);

// --- NUEVA LÓGICA DE PROGRESO ---
const lessonIds = lessons?.map(l => l.id) || [];

// 4. Obtener todos los ejercicios de estas lecciones (¡Con Token!)
const { data: allExercises } = await supabase
  .from("exercises")
  .select("id, lesson_id")
  .in("lesson_id", lessonIds)
  .setHeader('Authorization', `Bearer ${token}`);

// 5. Obtener los intentos del usuario (¡Con Token!)
const exerciseIds = allExercises?.map(e => e.id) || [];
let attemptedExerciseIds = new Set();

if (userId && exerciseIds.length > 0) {
  const { data: attempts } = await supabase
    .from("user_attempts")
    .select("exercise_id")
    .eq("user_id", userId)
    .in("exercise_id", exerciseIds)
    .setHeader('Authorization', `Bearer ${token}`);
  
  attemptedExerciseIds = new Set(attempts?.map(a => a.exercise_id));
}

// 6. Combinar datos: Calcular progreso por cada lección
const lessonsWithProgress = lessons?.map(lesson => {
  const lessonExercises = allExercises?.filter(e => e.lesson_id === lesson.id) || [];
  const total = lessonExercises.length;
  const completed = lessonExercises.filter(e => attemptedExerciseIds.has(e.id)).length;
  const percentage = total > 0 ? Math.round((completed / total) * 100) : 0;
  
  return { ...lesson, total, completed, percentage };
}) || [];
---

<DashboardLayout title={`Módulo: ${moduleData.title}`}>
  
  <div class="mb-6">
    <a href="/dashboard" class="text-primary hover:underline text-sm font-medium">
      &larr; Zurück zum Dashboard
    </a>
  </div>

  <div class="bg-card p-8 rounded-2xl border-2 border-border shadow-md mb-8">
    <h1 class="text-3xl font-bold mb-2 text-textMain flex gap-2">
      <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      {moduleData.title}
    </h1>
    <p class="text-textMain/70 text-lg">{moduleData.description}</p>
  </div>

  <h2 class="text-2xl font-bold mb-6 text-textMain">Lehren aus diesem Modul</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {lessonsWithProgress.map((lesson) => (
      <a 
        href={`/lesson/${lesson.id}`}
        class="flex flex-col h-full bg-card border-2 border-border rounded-xl p-6 hover:border-primary hover:shadow-md transition-all group relative overflow-hidden"
      >
        {lesson.percentage === 100 && (
          <div class="absolute inset-0 bg-green-50/30 pointer-events-none"></div>
        )}

        <div class="flex-grow relative z-10">
          <div class="flex justify-between items-start mb-2">
            <span class="text-xs font-bold text-primary uppercase tracking-wider block">
              Lektion {moduleData.order_index}.{lesson.order_index}
            </span>
            {lesson.percentage === 100 && (
              <span class="text-green-500" title="Completada">✅</span>
            )}
          </div>
          
          <h3 class="text-lg font-bold text-textMain mb-3 group-hover:text-primary transition-colors">
            {lesson.title}
          </h3>
          <p class="text-sm text-textMain/70 line-clamp-2 mb-4">
            {lesson.content}
          </p>

          <div class="mt-auto">
            <div class="flex justify-between text-xs font-medium text-textMain/60 mb-1">
              <span>Fortschritt</span>
              <span>{lesson.percentage}%</span>
            </div>
            <div class="h-1.5 w-full bg-border rounded-full overflow-hidden">
              <div 
                class={`h-full transition-all duration-500 ${lesson.percentage === 100 ? 'bg-green-500' : 'bg-primary'}`}
                style={`width: ${lesson.percentage}%`}
              ></div>
            </div>
          </div>
        </div>
        
        <div class="mt-6 pt-4 border-t border-border flex items-center justify-between text-sm font-medium text-primary relative z-10">
          <span>{lesson.percentage === 100 ? 'Lektion wiederholen' : lesson.percentage > 0 ? 'Setzen Sie die Lektion fort' : 'Betreten Sie die Lektion'}</span>
          <span class="transform group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    ))}
  </div>

  {lessonsWithProgress.length === 0 && (
    <div class="text-center p-8 border border-border rounded-xl bg-card">
      <p class="text-textMain/60">Für dieses Modul wurden noch keine Lektionen erstellt.</p>
    </div>
  )}

</DashboardLayout>