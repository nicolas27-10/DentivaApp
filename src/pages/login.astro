---
import AuthLayout from '../layouts/AuthLayout.astro';
// TODO: Supabase auth - handle form submit, redirect to dashboard on success
import { signIn } from '../lib/auth';
import { getSession } from "../lib/auth";

const session = await getSession(Astro.cookies);

if (session) {
  return Astro.redirect("/dashboard");
}

let errorMessage: string | null = null;
let successMessage: string | null = null;

if (Astro.request.method === 'POST') {
  const contentType = Astro.request.headers.get('content-type') ?? '';

  if (
    !contentType.includes('application/x-www-form-urlencoded') &&
    !contentType.includes('multipart/form-data')
  ) {
    errorMessage = 'Das Formular konnte nicht verarbeitet werden (Content-Type inválido).';
  } else {
    const formData = await Astro.request.formData();
    const { error } = await signIn(formData, Astro.cookies);
    if (error) {
      errorMessage = error.message ?? 'Wir konnten uns nicht einloggen.';
    } else {
      successMessage = 'Inicio de sesión exitoso.';
      return Astro.redirect('/dashboard')
    }
  }
}
---

<AuthLayout title="Login - Dentiva">
  <h1 class="text-2xl font-bold text-textMain mb-6">Login</h1>
  <form class="space-y-4" method="post" action="/login" enctype="multipart/form-data">
    {errorMessage && (
      <p class="mb-4 text-sm text-error bg-error/10 border border-error/30 rounded-lg px-4 py-3">
        {errorMessage}
      </p>
    )}
    {successMessage && (
      <p class="mb-4 text-sm text-success bg-success/10 border border-success/30 rounded-lg px-4 py-3">
        {successMessage}
      </p>
    )}
    <div>
      <label for="email" class="block text-sm font-medium text-textMain/80 mb-1">
        E-Mail-Adresse
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
        placeholder="deine@email.de"
      />
    </div>
    <div>
      <label for="password" class="block text-sm font-medium text-textMain/80 mb-1">
        Passwort
      </label>
      <input
        type="password"
        id="password"
        name="password"
        required
        class="w-full px-4 py-2 border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary bg-card text-textMain"
      />
    </div>
    <button
      type="submit"
      class="w-full py-3 px-4 bg-accent hover:bg-accent/90 text-white font-medium rounded-lg transition-colors"
    >
      Login
    </button>
  </form>
  <p class="mt-4 text-sm text-textMain/70">
    Hast du kein Konto? <a href="/register" class="text-primary hover:underline">Melden Sie sich an</a>
  </p>
</AuthLayout>
