---
import MainLayout from '../layouts/MainLayout.astro';
import LeaderboardTable from '../components/LeaderboardTable.astro';
import { getSession } from "../lib/auth";

const session = await getSession(Astro.cookies);


// TODO: Leaderboard system - fetch from Supabase, filter by week
---

<MainLayout title="Rangliste - Dentiva">
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-3xl font-bold text-textMain mb-2">Wöchentliche Rangliste</h1>
      <p class="text-textMain/70 mb-8">
        Top 10 der Woche. Steige in der Rangliste auf, indem du Quizze absolvierst!
      </p>
      <LeaderboardTable />
    </div>
  </section>
</MainLayout>
