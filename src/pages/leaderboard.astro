---
import MainLayout from '../layouts/MainLayout.astro';
import LeaderboardTable from '../components/LeaderboardTable.astro';

// TODO: Leaderboard system - fetch from Supabase, filter by week
---

<MainLayout title="Clasificación - Dentiva">
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-4xl">
      <h1 class="text-3xl font-bold text-slate-900 mb-2">Clasificación semanal</h1>
      <p class="text-slate-600 mb-8">
        Top 10 de la semana. ¡Participa completando quizzes para subir posiciones!
      </p>
      <LeaderboardTable />
    </div>
  </section>
</MainLayout>
