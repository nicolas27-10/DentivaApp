---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import { supabase } from "../../lib/supabaseClient";

const { id } = Astro.params;

const { data: lesson } = await supabase
  .from("lessons")
  .select("*")
  .eq("id", id)
  .single();

const { data: exercises } = await supabase
  .from("exercises")
  .select("*")
  .eq("lesson_id", id)
  .order("order_index");
---

<DashboardLayout title={lesson.title}>

<h1 class="text-2xl font-bold mb-4">{lesson.title}</h1>

<p class="mb-8 text-textMain/80">
  {lesson.content}
</p>

<h2 class="text-lg font-semibold mb-4">Ejercicios</h2>

<div class="space-y-4">

{exercises?.map((exercise) => (
<a
href={`/exercise/${exercise.id}`}
class="block border border-border rounded-lg p-4 hover:border-primary"
>
Ejercicio {exercise.order_index}
</a>
))}

</div>

</DashboardLayout>