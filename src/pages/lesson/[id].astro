---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import VerticalQuiz from "../../components/VerticalQuiz"; // 👈 Importamos nuestro nuevo componente
import { supabase } from "../../lib/supabaseClient";

const { id } = Astro.params;

// 1. Obtener el usuario actual
const { data: { session } } = await supabase.auth.getSession();
const userId = session?.user?.id;

// Si no hay usuario, redirigir al login (buena práctica)
if (!userId) {
  return Astro.redirect('/login');
}

// 2. Obtener la información de la lección
const { data: lesson } = await supabase
  .from("lessons")
  .select("*")
  .eq("id", id)
  .single();

if (!lesson) {
  return Astro.redirect('/dashboard?error=lesson_not_found');
}

// 3. LA GRAN MEJORA: Obtener los ejercicios CON sus opciones y respuestas de una sola vez
const { data: exercises } = await supabase
  .from("exercises")
  .select(`
    id,
    type,
    question_text,
    explanation,
    order_index,
    exercise_options (
      id,
      option_text,
      is_correct
    )
  `)
  .eq("lesson_id", id)
  .order("order_index");

  console.log("--- DEBUG SUPABASE ---");
console.log("ID de la lección actual:", id);
console.log("Error de Supabase:", Error);
console.log("Ejercicios encontrados:", exercises);
console.log("----------------------");

// Como ahora el cliente evalúa, ya no necesitamos calcular el progreso individual de cada pregunta en el servidor
// Simplemente le pasamos las preguntas al componente de React.
---

<DashboardLayout title={lesson.title}>
  <div class="max-w-3xl mx-auto">

    <div class="mb-6">
      <a href={`/module/${lesson.module_id}`} class="text-primary hover:underline text-sm font-medium">
        &larr; Volver al módulo
      </a>
    </div>
    
    <div class="mb-8 bg-card p-6 rounded-2xl border border-border shadow-sm">
      <h1 class="text-3xl font-bold mb-4">{lesson.title}</h1>
      <div class="prose prose-sm text-textMain/80">
        <p>{lesson.content}</p>
      </div>
    </div>

    <div class="mt-8">
      <h2 class="text-xl font-semibold mb-6 text-textMain">Ejercicios de la Lección</h2>
      
      {exercises && exercises.length > 0 ? (
        <VerticalQuiz 
          client:load 
          exercises={exercises} 
          userId={userId} 
          lessonId={Number(id)} 
          moduleId={lesson.module_id}
        />
      ) : (
        <p class="text-gray-500 text-center py-8">Aún no hay ejercicios para esta lección.</p>
      )}
    </div>

  </div>
</DashboardLayout>