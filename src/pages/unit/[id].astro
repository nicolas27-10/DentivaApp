---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import QuestionCard from '../../components/QuestionCard.astro';
import { supabase } from "../../lib/supabaseClient";

export const prerender = false

// TODO: Supabase - fetch unit content by id
// TODO: Quiz logic - implement quiz engine, scoring, progress tracking
const { id } = Astro.params;


const { data: module } = await supabase
  .from("modules")
  .select("*")
  .eq("id", id)
  .single();

  const { data: firstLesson } = await supabase
  .from("lessons")
  .select("id")
  .eq("module_id", id)
  .order("order_index", { ascending: true })
  .limit(1)
  .single();
---

<DashboardLayout title={`Unidad ${id} - Dentiva`}>
  <div class="mb-6">
    <a href="/dashboard" class="text-sm text-primary hover:underline">← Volver al dashboard</a>
  </div>

  <section class="mb-12">
    <h1 class="text-2xl font-bold text-textMain mb-2">Unidad {id}: {module.title}</h1>
    <p class="text-textMain/70 mb-6">
      Material de estudio (placeholder). El contenido se cargará desde la base de datos.
    </p>
    <div class="bg-card rounded-lg border border-border p-8 shadow-sm min-h-[200px]">
      <p class="text-textMain/60 italic">
        [Placeholder: aquí se mostrará el material de estudio. Integración con Supabase storage/docs pendiente.]
      </p>
    </div>
  </section>

  <!-- <section class="mb-8">
    <h2 class="text-lg font-semibold text-textMain mb-4">Quiz de la unidad</h2>
    <p class="text-textMain/70 mb-4">
      Comprueba tus conocimientos con este quiz. La lógica del quiz se implementará posteriormente.
    </p>
    <a
      href="#quiz"
      class="inline-flex items-center justify-center px-6 py-3 bg-accent hover:bg-accent/90 text-white font-medium rounded-lg transition-colors"
    >
      Iniciar quiz
    </a>
  </section>

  <section id="quiz" class="mt-12">
    <QuestionCard
      question="Pregunta de ejemplo: ¿Cuál es la estructura principal del esmalte dental?"
      options={['Hidroxiapatita', 'Colágeno', 'Queratina', 'Elastina']}
      questionIndex={1}
      totalQuestions={10}
    />
  </section> -->

  <section class="mb-8">
    {firstLesson && (
      <div class="mt-8">
        <a
          href={`/lesson/${firstLesson.id}`}
          class="inline-flex items-center px-6 py-3 bg-accent hover:bg-accent/90 text-white font-medium rounded-lg transition-colors"
        >
          Comenzar lección
        </a>
      </div>
    )}
  </section>
</DashboardLayout>
