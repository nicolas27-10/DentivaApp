---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import QuestionCard from '../../components/QuestionCard.astro';

// TODO: Supabase - fetch unit IDs from database
export function getStaticPaths() {
  return [{ params: { id: '1' } }, { params: { id: '2' } }, { params: { id: '3' } }];
}

// TODO: Supabase - fetch unit content by id
// TODO: Quiz logic - implement quiz engine, scoring, progress tracking
const { id } = Astro.params;
---

<DashboardLayout title={`Unidad ${id} - Dentiva`}>
  <div class="mb-6">
    <a href="/dashboard" class="text-sm text-teal-600 hover:underline">← Volver al dashboard</a>
  </div>

  <section class="mb-12">
    <h1 class="text-2xl font-bold text-slate-900 mb-2">Unidad {id}</h1>
    <p class="text-slate-600 mb-6">Material de estudio (placeholder). El contenido se cargará desde la base de datos.</p>
    <div class="bg-white rounded-lg border border-slate-200 p-8 shadow-sm min-h-[200px]">
      <p class="text-slate-500 italic">
        [Placeholder: aquí se mostrará el material de estudio. Integración con Supabase storage/docs pendiente.]
      </p>
    </div>
  </section>

  <section class="mb-8">
    <h2 class="text-lg font-semibold text-slate-900 mb-4">Quiz de la unidad</h2>
    <p class="text-slate-600 mb-4">
      Comprueba tus conocimientos con este quiz. La lógica del quiz se implementará posteriormente.
    </p>
    <a
      href="#quiz"
      class="inline-flex items-center justify-center px-6 py-3 bg-teal-600 hover:bg-teal-700 text-white font-medium rounded-lg transition-colors"
    >
      Iniciar quiz
    </a>
  </section>

  <section id="quiz" class="mt-12">
    <QuestionCard
      question="Pregunta de ejemplo: ¿Cuál es la estructura principal del esmalte dental?"
      options={['Hidroxiapatita', 'Colágeno', 'Queratina', 'Elastina']}
      questionIndex={1}
      totalQuestions={10}
    />
  </section>
</DashboardLayout>
