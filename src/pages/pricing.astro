---
import MainLayout from '../layouts/MainLayout.astro';
import PricingTable from '../components/PricingTable.astro';
---

<MainLayout title="Precios - Dentiva">
  <section class="py-16 px-4">
    <div class="container mx-auto max-w-5xl">
      <h1 class="text-3xl font-bold text-textMain text-center mb-4">Planes de suscripción</h1>
      <p class="text-textMain/70 text-center mb-12 max-w-2xl mx-auto">
        Accede a todo el material de estudio, quizzes ilimitados y clasificación semanal. 
        Sin compromiso de permanencia.
      </p>
      <PricingTable />
    </div>
  </section>
</MainLayout>
