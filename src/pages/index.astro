---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import PricingTable from '../components/PricingTable.astro';
---

<MainLayout title="Dentiva - Valida tu título dental en Alemania">
  <Hero />
  <Features />
  <PricingTable />
  <section class="py-20 px-4 bg-teal-600 text-white">
    <div class="container mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-bold mb-4">
        ¿Listo para empezar?
      </h2>
      <p class="mb-8 text-teal-100">
        Regístrate gratis y accede a material de muestra. Desbloquea todo el contenido con una suscripción.
      </p>
      <a
        href="/register"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-teal-600 bg-white hover:bg-teal-50 rounded-lg transition-colors"
      >
        Crear cuenta gratuita
      </a>
    </div>
  </section>
</MainLayout>
