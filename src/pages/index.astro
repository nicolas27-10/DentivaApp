---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import PricingTable from '../components/PricingTable.astro';
import LeaderboardTable from '@/components/LeaderboardTable.astro';
---

<MainLayout title="Dentiva - Valida tu título dental en Alemania">
  <Hero />
  <Features />
  <section id="leaderboard" class="py-16 px-4 scroll-m-16">
    <div class="container mx-auto max-w-4xl text-center">
      <h2 class="text-3xl font-bold text-textMain mb-4">
        Únete a nuestra comunidad activa 🏆
      </h2>
      <p class="text-textMain/70 mb-10 max-w-2xl mx-auto">
        Cientos de odontólogos ya se están preparando para su examen en Alemania. ¡Mira quiénes lideran el ranking esta semana!
      </p>
      
      {/* Tu componente de tabla */}
      <LeaderboardTable />
      
    </div>
  </section>
  <PricingTable />
  <section class="py-20 px-4 bg-accent text-white">
    <div class="container mx-auto max-w-3xl text-center">
      <h2 class="text-2xl font-bold mb-4">
        ¿Listo para empezar?
      </h2>
      <p class="mb-8 text-background/80">
        Regístrate gratis y accede a material de muestra. Desbloquea todo el contenido con una suscripción.
      </p>
      <a
        href="/register"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-accent bg-card hover:bg-background rounded-lg transition-colors"
      >
        Crear cuenta gratuita
      </a>
    </div>
  </section>
</MainLayout>
