---
interface Props {
  id: string;
  title: string;
  description?: string;
  progress?: number;
  quizCount?: number;
}

const { id, title, description = '', progress = 0, quizCount = 0 } = Astro.props;
---

<a
  href={`/unit/${id}`}
  class="box-border block p-6 bg-card rounded-2xl ring-border ring-2 border-primary shadow-primary hover:ring-primary hover:-translate-y-1 transition-all border-t-8"
>
  <div class="flex items-start justify-between">
    <div>
      <h3 class="text-lg font-semibold text-textMain">{title}</h3>
      {description && (
        <p class="text-textMain/70 text-sm mt-1 line-clamp-2">{description}</p>
      )}
      {quizCount > 0 && (
        <p class="text-xs text-textMain/60 mt-2">{quizCount} quiz(zes)</p>
      )}
    </div>
  </div>
  {progress > 0 && (
    <div class="mt-4">
      <div class="flex justify-between text-xs text-textMain/60 mb-1">
        <span>Progreso</span>
        <span>{progress}%</span>
      </div>
      <div class="h-2 bg-border rounded-full overflow-hidden">
        <div
          class="h-full bg-primary rounded-full transition-all"
          style={`width: ${progress}%`}
        />
      </div>
    </div>
  )}
</a>
