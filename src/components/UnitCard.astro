---
interface Props {
  id: string;
  title: string;
  description?: string;
  progress?: number;
  quizCount?: number;
  isLocked?: boolean; // 👈 1. Nueva prop para el estado de bloqueo
}

const { 
  id, 
  title, 
  description = '', 
  progress = 0, 
  quizCount = 0, 
  isLocked = false 
} = Astro.props;

// 👈 2. Lógica de clases dinámicas para Tailwind
const baseClasses = "box-border block p-6 bg-card rounded-2xl ring-2 transition-all border-t-8 relative";
const activeClasses = "ring-border border-primary shadow-primary hover:ring-primary hover:-translate-y-1";
const lockedClasses = "ring-border/50 border-gray-400 opacity-60 grayscale cursor-not-allowed";

const cardClasses = `${baseClasses} ${isLocked ? lockedClasses : activeClasses}`;
---

<a
  href={isLocked ? undefined : `/module/${id}`} 
  class={cardClasses}
  aria-disabled={isLocked}
>
  <div class="flex items-start justify-between">
    <div class="pr-8"> <h3 class="text-lg font-semibold text-textMain">{title}</h3>
      {description && (
        <p class="text-textMain/70 text-sm mt-1 line-clamp-2">{description}</p>
      )}
      {quizCount > 0 && (
        <p class="text-xs text-textMain/60 mt-2">{quizCount} quiz(zes)</p>
      )}
    </div>

    {isLocked && (
      <div class="absolute top-6 right-6 text-textMain/60">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
      </div>
    )}
  </div>

  {!isLocked && progress > 0 && (
    <div class="mt-4">
      <div class="flex justify-between text-xs text-textMain/60 mb-1">
        <span>Progreso</span>
        <span>{progress}%</span>
      </div>
      <div class="h-2 bg-border rounded-full overflow-hidden">
        <div
          class="h-full bg-primary rounded-full transition-all"
          style={`width: ${progress}%`}
        />
      </div>
    </div>
  )}
</a>