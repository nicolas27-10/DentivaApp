---
const currentYear = new Date().getFullYear();
---

<footer class="bg-background border-t border-border py-12 px-4">
  <div class="container mx-auto max-w-6xl">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <a href="/" class="flex items-center gap-2 cursor-pointer">
        <img src="/DentivaLogo.png" alt="Dentiva" class="h-12 rounded-lg bg-none" />
      </a>
      <div class="flex gap-8 text-sm text-textMain/70">
        <a href="/" class="hover:text-primary">Inicio</a>
        <a href="/pricing" class="hover:text-primary">Precios</a>
        <a href="/leaderboard" class="hover:text-primary">Clasificación</a>
        <a href="/login" class="hover:text-primary">Iniciar sesión</a>
        <a href="/register" class="hover:text-primary">Registrarse</a>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-border text-center text-sm text-textMain/60">
      © {currentYear} DentivaApp. Plataforma educativa para dentistas.
    </div>
  </div>
</footer>
