---
import { getSession } from "@/lib/auth";

// Verificamos si hay una sesión activa
const user = await getSession(Astro.cookies);

const currentYear = new Date().getFullYear();
---

<footer class="bg-background border-t border-border py-12 px-4">
  <div class="container mx-auto max-w-6xl">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      
      <a href="/" class="flex items-center gap-2 cursor-pointer hover:opacity-90 transition-opacity">
        <img src="/DentivaLogo.png" alt="Dentiva" class="h-12 rounded-lg bg-none" />
      </a>
      
      <div class="flex flex-wrap justify-center gap-6 md:gap-8 text-sm text-textMain/70 font-medium">
        <a href="/" class="hover:text-primary transition-colors">Startseite</a>
        <a href="/pricing" class="hover:text-primary transition-colors">Preise</a>
        <a href="/leaderboard" class="hover:text-primary transition-colors">Rangliste</a>
        
        {/* Lógica condicional: Si NO hay usuario, muestra Login/Registro. Si SÍ hay, muestra Dashboard */}
        {!user ? (
          <>
            <a href="/login" class="hover:text-primary transition-colors">Anmelden</a>
            <a href="/register" class="hover:text-primary transition-colors">Registrieren</a>
          </>
        ) : (
          <a href="/dashboard" class="hover:text-primary transition-colors">Mein Dashboard</a>
        )}
      </div>

    </div>
    
    <nav
      class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-xs text-textMain/55"
      aria-label="Rechtliche Hinweise"
    >
      <a href="/impressum" class="hover:text-primary transition-colors">Impressum</a>
      <a href="/datenschutz" class="hover:text-primary transition-colors">Datenschutz</a>
      <a href="/agb" class="hover:text-primary transition-colors">AGB</a>
    </nav>

    <div class="mt-4 pt-6 border-t border-border text-center text-sm text-textMain/60">
      © {currentYear} DentivaApp. Bildungsplattform.
    </div>
  </div>
</footer>