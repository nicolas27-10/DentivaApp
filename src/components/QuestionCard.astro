---
// TODO: Quiz engine - implement question rendering, answer validation, score calculation
interface Props {
  question?: string;
  options?: string[];
  questionIndex?: number;
  totalQuestions?: number;
}

const {
  question = 'Beispielfrage (Platzhalter)',
  options = ['Option A', 'Option B', 'Option C', 'Option D'],
  questionIndex = 1,
  totalQuestions = 10,
} = Astro.props;
---

<div class="bg-card rounded-lg border border-border p-6 shadow-sm">
  <div class="text-sm text-textMain/60 mb-4">
    Frage {questionIndex} von {totalQuestions}
  </div>
  <p class="text-lg font-medium text-textMain mb-6">{question}</p>
  <ul class="space-y-3">
    {options.map((opt, i) => (
      <li>
        <label
          class="flex items-center gap-3 p-4 rounded-lg border border-border hover:border-primary cursor-pointer transition-colors"
        >
          <input type="radio" name="answer" value={i} class="text-primary" />
          <span class="text-textMain/80">{opt}</span>
        </label>
      </li>
    ))}
  </ul>
  <p class="text-xs text-textMain/50 mt-4 italic">
    [Platzhalter: Die Quiz-Logik wird später implementiert]
  </p>
</div>
