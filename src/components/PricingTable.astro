---
// src/components/PricingTable.astro
import { supabase } from "../lib/supabaseClient";

interface Props {
  isPremium?: boolean;
}

const { isPremium = false } = Astro.props;
const accessToken = Astro.cookies.get('sb-access-token')?.value;

type Plan = {
  name: string;
  price: string;
  originalPrice?: string; 
  period: string;
  priceId: string;
  features?: string[];
  cta: string;
  highlight: boolean;
  launchBadge?: string; 
};

const plans: Plan[] = [
  {
    name: 'Monatlich',
    price: '34',
    period: 'Monat',
    priceId: 'price_1TwH8fFC01ay7GXxz2gxfdJA', 
    features: ['Vollständiger Zugriff', 'Unbegrenzte Quizzes', 'Gespeicherter Fortschritt', 'Ranking'],
    cta: 'Jetzt starten',
    highlight: false,
  },
  {
    name: '3-Monats-Paket',
    price: '89',
    period: '3 Monate',
    priceId: 'price_1TwH9DFC01ay7GXxIagut9NX', 
    features: ['Alles aus Monatlich', 'Nur ~€29 pro Monat', '13% Ersparnis', 'Ideal für die FSP'],
    cta: 'Paket wählen',
    highlight: false,
  },
  {
    name: 'Einführungsangebot',
    price: '69',
    originalPrice: '89', // Precio que se verá tachado
    period: '3 Monate',
    priceId: 'price_1TwH8wFC01ay7GXxCpDobxgu', 
    features: ['Alles aus 3 Monate', 'Für die ersten 50 Nutzer', 'Größte Ersparnis', 'Perfekt für die FSP'],
    cta: 'Angebot sichern',
    highlight: true,
    launchBadge: 'Nur noch wenige Plätze!', // Etiqueta roja de escasez
  },
];
---

<section class="py-10 px-4">
  <div class="grid md:grid-cols-3 gap-8 mx-auto max-w-5xl"> 
    {plans.map((plan) => (
      <div
        class={`relative rounded-3xl border p-8 flex flex-col ${
          plan.highlight ? 'border-primary bg-card shadow-lg ring-2 ring-primary/10' : 'border-border bg-card'
        }`}
      >
        {/* Etiqueta de lanzamiento o destacado */}
        {plan.launchBadge ? (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-red-500 text-white text-xs font-bold px-4 py-1 rounded-full uppercase whitespace-nowrap shadow-sm animate-pulse">
            {plan.launchBadge}
          </span>
        ) : plan.highlight && (
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase">
            Empfohlen
          </span>
        )}
        
        <h3 class="text-xl font-bold text-textMain mb-2">{plan.name}</h3>
        
        {/* Bloque de precios */}
        <div class="mb-6 flex items-baseline gap-2">
          {plan.originalPrice && (
            <span class="text-textMain/40 text-2xl font-medium line-through">€{plan.originalPrice}</span>
          )}
          <span class="text-4xl font-extrabold text-textMain">€{plan.price}</span>
          <span class="text-textMain/70">/{plan.period}</span>
        </div>

        <ul class="space-y-3 mb-8 flex-grow">
          {plan.features?.map((f) => (
            <li class="flex items-start gap-2 text-sm text-textMain/80">
              <span class="text-green-500 font-bold">✓</span>
              {f}
            </li>
          ))}
        </ul>
        
        {isPremium ? (
          <a
            href="/dashboard"
            class="block w-full text-center py-3 px-4 rounded-xl font-bold bg-slate-100 text-slate-500 hover:bg-slate-200 transition-colors"
          >
            Abonniert — Zum Dashboard
          </a>
        ) : (
          <button
            data-price-id={plan.priceId}
            class={`checkout-button block w-full text-center py-3 px-4 rounded-xl font-bold transition-all transform active:scale-95 ${
              plan.highlight
                ? 'bg-primary text-white hover:bg-primary/90 shadow-md'
                : 'bg-background border border-border text-textMain hover:bg-slate-50'
            }`}
          >
            {plan.cta}
          </button>
        )}
      </div>
    ))}
  </div>
</section>

<div id="auth-context" data-token={accessToken}></div>

<script>
  import { supabase } from "../lib/supabaseClient";

  const checkoutButtons = document.querySelectorAll('.checkout-button');
  const authContext = document.getElementById('auth-context');
  const accessToken = authContext?.dataset.token;

  checkoutButtons.forEach(button => {
    button.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const priceId = btn.dataset.priceId;

      if (!priceId) return;
      if (!accessToken) {
        alert("Bitte melden Sie sich an, um ein Abonnement abzuschließen.");
        window.location.href = "/login";
        return;
      }

      const originalText = btn.innerText;
      btn.innerText = "Wird verarbeitet...";
      btn.disabled = true;

      try {
        const { data, error } = await supabase.auth.getUser(accessToken);
        if (error || !data?.user) throw new Error("Sitzung abgelaufen. Bitte erneut anmelden.");

        const response = await fetch('/api/create-checkout-session', {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${accessToken}`
          },
          body: JSON.stringify({ priceId }),
        });

        const sessionData = await response.json();
        if (sessionData.url) {
          window.location.href = sessionData.url;
        } else {
          throw new Error(sessionData.error || 'Fehler beim Erstellen der Sitzung');
        }
      } catch (error: any) {
        alert(error.message);
        btn.innerText = originalText;
        btn.disabled = false;
        if (error.message.includes("Sitzung")) window.location.href = "/login";
      }
    });
  });
</script>