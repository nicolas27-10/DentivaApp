---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Valida tu título dental en Alemania',
  subtitle = 'Material de estudio, quizzes interactivos y seguimiento de progreso. Todo lo que necesitas para aprobar el examen de homologación.',
} = Astro.props;
---

<section class="py-20 px-4 bg-white">
  <div class="container mx-auto max-w-4xl text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
      {title}
    </h1>
    <p class="text-xl text-slate-600 mb-10 max-w-2xl mx-auto">
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/register"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-teal-600 hover:bg-teal-700 rounded-lg transition-colors"
      >
        Comenzar gratis
      </a>
      <a
        href="/pricing"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-teal-600 bg-teal-50 hover:bg-teal-100 rounded-lg border border-teal-200 transition-colors"
      >
        Ver planes
      </a>
    </div>
  </div>
</section>
