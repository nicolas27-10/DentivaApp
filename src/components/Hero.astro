---
interface Props {
  subtitle?: string;
}

const {
  subtitle = 'Material de estudio, quizzes interactivos y seguimiento de progreso. Todo lo que necesitas para aprobar el examen de homologación.',
} = Astro.props;
---

<section class="py-20 px-4 bg-background">
  <div class="container mx-auto max-w-4xl text-center">
    <h1 class="text-4xl md:text-5xl font-bold text-textMain mb-6">
      Valida tu título dental en Alemania con <span class="text-6xl text-primary mt-8 block">Dentiva<span class="text-textMain/70">App</span></span>
    </h1>
    <p class="text-xl text-textMain/70 mb-10 max-w-2xl mx-auto">
      {subtitle}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/register"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white bg-accent hover:bg-accent/90 rounded-lg transition-colors"
      >
        Comenzar gratis
      </a>
      <a
        href="/pricing"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-medium text-primary bg-card hover:bg-background rounded-lg border border-border transition-colors"
      >
        Ver planes
      </a>
    </div>
  </div>
</section>
