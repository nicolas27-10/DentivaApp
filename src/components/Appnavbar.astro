---
import { getSession, signOut } from "@/lib/auth";

const user = await getSession(Astro.cookies);
const currentPath = Astro.url.pathname;

// Función para saber si estamos en la ruta
const isActive = (path: string) => currentPath === path;

// Ahora los links incluyen un SVG (Icono)
const navLinks = [
  { 
    href: '/dashboard', 
    label: 'Progreso', 
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18 M7 16l4-4 4 4 4-6" />' 
  },
  { 
    href: '/aprender', 
    label: 'Aprender', 
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />' 
  },
  { 
    href: '/fsp', 
    label: 'FSP-Vorbereitung', 
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />' 
  },
  { 
    href: '/leaderboard', 
    label: 'Clasificación', 
    icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />' 
  },
];

if (Astro.request.method === "POST") {
  await signOut(Astro.cookies);
  return Astro.redirect("/login");
}
---

<nav class="bg-white border-b-2 border-border/60 sticky top-0 z-50">
  <div class="px-4 lg:px-8">
    <div class="flex items-center justify-between h-16">
      
        <a href="/" class="flex items-center gap-2 hover:opacity-90 transition-opacity cursor-pointer">
            <img src="/DentivaLogo.png" alt="Dentiva" class="h-12 rounded-lg" />
          </a>

      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`flex items-center gap-2 px-4 py-2 rounded-xl text-[13px] font-bold transition-all ${
              isActive(link.href)
                ? 'bg-[#E4F6FD] text-[#1A8AB8]' 
                : 'text-textMain/60 hover:bg-slate-50 hover:text-textMain'
            }`}
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={link.icon} />
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-4">
        
        <div class="hidden sm:flex items-center gap-1.5 bg-[#0E1C26] text-white px-3.5 py-1.5 rounded-full text-xs font-bold shadow-sm">
          <svg class="w-4 h-4 text-[#F07830]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
          </svg>
          12 Días
        </div>

        <div class="relative group cursor-pointer">
          <div class="w-10 h-10 bg-[#E4F6FD] border-2 border-[#C0DFF0] rounded-full flex items-center justify-center text-[#3AAEDC]">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>

          <div class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-lg border border-border opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="p-2">
              
              <div class="px-4 py-2 border-b border-border mb-1">
                <p class="text-xs text-textMain/60">Conectado como</p>
                <p class="text-sm font-bold text-textMain truncate" title={user?.email}>{user?.email}</p>
              </div>
              <a href="/profile" class="block px-4 py-2 text-sm font-medium text-textMain hover:bg-slate-50 rounded-lg">Mi Perfil</a>
              <form method="POST" class="w-full m-0">
                <button type="submit" class="w-full text-left px-4 py-2 text-sm font-medium text-error hover:bg-red-50 rounded-lg transition-colors">
                  Cerrar sesión
                </button>
              </form>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</nav>