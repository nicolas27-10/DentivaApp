---
const features = [
  {
    title: 'Lernmaterialien',
    description: 'Strukturierte Einheiten nach den Themen der deutschen Kenntnisprüfung.',
    icon: '📚',
  },
  {
    title: 'Interaktive Quizze',
    description: 'Teste dein Wissen mit realistischen Prüfungsfragen.',
    icon: '✓',
  },
  {
    title: 'Lernfortschritt',
    description: 'Behalte deine Erfolge im Blick und bleibe motiviert am Ball.',
    icon: '📊',
  },
  {
    title: 'Wöchentliche Bestenliste',
    description: 'Messe dich mit anderen Zahnärzten und steigere deine Motivation.',
    icon: '🏆',
  },
];
---

<section class="py-20 px-4 bg-background">
  <div class="container mx-auto max-w-6xl">
    <h2 class="text-3xl font-bold text-textMain text-center mb-4">
      Alles, was du zum Bestehen brauchst
    </h2>
    <p class="text-textMain/70 text-center mb-16 max-w-2xl mx-auto">
      Eine Plattform speziell für ausländische Zahnärzte auf dem Weg zur deutschen Approbation.
    </p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map((feature) => (
        <div class="bg-card p-6 rounded-lg border border-border shadow-sm hover:shadow-md transition-shadow">
          <div class="text-3xl mb-4">{feature.icon}</div>
          <h3 class="text-lg font-semibold text-textMain mb-2">
            {feature.title}
          </h3>
          <p class="text-textMain/70 text-sm">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>