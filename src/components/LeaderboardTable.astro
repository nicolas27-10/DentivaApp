---
// TODO: Leaderboard system - fetch real data from Supabase, filter by week
interface Props {
  entries?: Array<{ rank: number; username: string; score: number; country?: string }>;
}

const {
  entries = [
    { rank: 1, username: 'dentista_2024', score: 2450, country: 'España' },
    { rank: 2, username: 'dr_schmidt', score: 2320, country: 'Alemania' },
    { rank: 3, username: 'maria_odont', score: 2180, country: 'Colombia' },
    { rank: 4, username: 'carlos_dds', score: 2050, country: 'México' },
    { rank: 5, username: 'laura_dent', score: 1980, country: 'Argentina' },
    { rank: 6, username: 'pablo_odonto', score: 1850, country: 'Chile' },
    { rank: 7, username: 'ana_periodont', score: 1720, country: 'Perú' },
    { rank: 8, username: 'jose_implantes', score: 1650, country: 'España' },
    { rank: 9, username: 'sofia_dent', score: 1580, country: 'Ecuador' },
    { rank: 10, username: 'miguel_ortho', score: 1490, country: 'Venezuela' },
  ],
} = Astro.props;
---

<div class="bg-card rounded-lg border border-border overflow-hidden shadow-sm">
  <table class="w-full">
    <thead class="bg-background border-b border-border">
      <tr>
        <th class="px-6 py-4 text-left text-xs font-semibold text-textMain/70 uppercase">#</th>
        <th class="px-6 py-4 text-left text-xs font-semibold text-textMain/70 uppercase">Usuario</th>
        <th class="px-6 py-4 text-left text-xs font-semibold text-textMain/70 uppercase">Puntos</th>
        <th class="px-6 py-4 text-left text-xs font-semibold text-textMain/70 uppercase">País</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-border">
      {entries.map((e) => (
        <tr class="hover:bg-background transition-colors">
          <td class="px-6 py-4 text-textMain font-medium">{e.rank}</td>
          <td class="px-6 py-4 text-textMain/80">{e.username}</td>
          <td class="px-6 py-4 text-primary font-semibold">{e.score}</td>
          <td class="px-6 py-4 text-textMain/70">{e.country ?? '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
